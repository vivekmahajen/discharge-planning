{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "../web_app.py",
          "../orchestrator.py",
          "../sample_patient.py",
          "../fhir/**",
          "../agents/**",
          "../utils/**",
          "../static/**",
          "../models/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/directory/cron-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
