ANTHROPIC_API_KEY=your_api_key_here
SECRET_KEY=change-this-to-a-random-secret-in-production
ALLOWED_EMAILS=user1@hospital.org,user2@hospital.org

# Postgres — set either of these; Vercel injects POSTGRES_URL automatically
# Leave blank to use local file-based storage (dev only)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# POSTGRES_URL=postgresql://user:password@host:5432/dbname
