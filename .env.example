ANTHROPIC_API_KEY=your_api_key_here
SECRET_KEY=change-this-to-a-random-secret-in-production
ALLOWED_EMAILS=user1@hospital.org,user2@hospital.org

# Postgres — set either of these; Vercel injects POSTGRES_URL automatically
# Leave blank to use local file-based storage (dev only)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# POSTGRES_URL=postgresql://user:password@host:5432/dbname

# ── FHIR R4 Connector ─────────────────────────────────────────────────────────
# App URL — used to build the OAuth redirect_uri
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Override if your redirect_uri differs from {APP_URL}/api/fhir/callback
# FHIR_REDIRECT_URI=https://your-app.vercel.app/api/fhir/callback

# Dedicated signing key for FHIR session cookies (falls back to SECRET_KEY if unset)
# FHIR_SESSION_SECRET=change-this-to-a-separate-random-secret

# ── Epic ──────────────────────────────────────────────────────────────────────
# Register at https://fhir.epic.com/developer (Epic App Orchard for production)
# Sandbox access is free and requires no approval — start here.
FHIR_CLIENT_ID_EPIC=your-epic-client-id
# Epic is a public client — no client secret needed (PKCE only)
# Sandbox FHIR base: https://fhir.epic.com/interconnect-ambu-oauth/api/FHIR/R4
# FHIR_BASE_URL_EPIC=https://your-hospitals-epic-instance/api/FHIR/R4
# Optional: override SMART discovery endpoints
# EPIC_AUTH_ENDPOINT=
# EPIC_TOKEN_ENDPOINT=

# ── Oracle Health (Cerner) ────────────────────────────────────────────────────
# Register at https://code.cerner.com/developer/smart-on-fhir
FHIR_CLIENT_ID_CERNER=your-cerner-client-id
# Sandbox FHIR base: https://fhir-ehr-code.cerner.com/r4/ec2458f2-1e24-41c8-b71b-0e701af7583d
# FHIR_BASE_URL_CERNER=https://fhir-ehr.cerner.com/r4/your-tenant-id
# CERNER_AUTH_ENDPOINT=
# CERNER_TOKEN_ENDPOINT=

# ── athenahealth ──────────────────────────────────────────────────────────────
# Register at https://developer.athenahealth.com (approved same day in sandbox)
# athenahealth is a CONFIDENTIAL client — store client_secret server-side only
FHIR_CLIENT_ID_ATHENA=your-athena-client-id
FHIR_CLIENT_SECRET_ATHENA=your-athena-client-secret
# Sandbox FHIR base: https://api.preview.platform.athenahealth.com/fhir/r4
# FHIR_BASE_URL_ATHENA=https://api.platform.athenahealth.com/fhir/r4
# ATHENA_AUTH_ENDPOINT=
# ATHENA_TOKEN_ENDPOINT=
